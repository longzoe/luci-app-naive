#!/bin/sh /etc/rc.common

USE_PROCD=1
START=95
STOP=10

CONF=naive
RUNDIR=/var/etc/naive
CFGFILE=$RUNDIR/config.json

. /usr/share/libubox/jshn.sh

build_config() {
  local cfg="$1"
  local listen_type listen_addr listen_port proxy_protocol server server_port username password

  config_get listen_type "$cfg" listen_type "socks"
  config_get listen_addr "$cfg" listen_addr "127.0.0.1"
  config_get listen_port "$cfg" listen_port "1080"
  config_get proxy_protocol "$cfg" proxy_protocol "https"
  config_get server "$cfg" server "example.com"
  config_get server_port "$cfg" server_port "443"
  config_get username "$cfg" username
  config_get password "$cfg" password

  [ -n "$server" ] || {
    logger -t naive "missing server domain"
    return 1
  }

  [ -n "$username" ] || {
    logger -t naive "missing username"
    return 1
  }

  [ -n "$password" ] || {
    logger -t naive "missing password"
    return 1
  }

  mkdir -p "$RUNDIR" || return 1

  json_init
  json_add_string listen "${listen_type}://${listen_addr}:${listen_port}"
  json_add_string proxy "${proxy_protocol}://${username}:${password}@${server}:${server_port}"
  json_dump > "$CFGFILE"
}

append_extra_args() {
  local extra_args="$1"
  local token

  set -f
  for token in $extra_args; do
    procd_append_param command "$token"
  done
  set +f
}

start_instance() {
  local cfg="$1"
  local enabled prog extra_args

  config_get_bool enabled "$cfg" enabled 0
  config_get prog "$cfg" binary_path "/usr/bin/naive"
  config_get extra_args "$cfg" extra_args
  [ "$enabled" -eq 1 ] || return 0

  [ -x "$prog" ] || {
    logger -t naive "binary not found or not executable: $prog"
    return 1
  }

  build_config "$cfg" || return 1

  procd_open_instance
  procd_set_param command "$prog" "$CFGFILE"
  [ -n "$extra_args" ] && append_extra_args "$extra_args"
  procd_set_param file /etc/config/naive "$CFGFILE"
  procd_set_param respawn
  procd_set_param stdout 1
  procd_set_param stderr 1
  procd_close_instance
}

start_service() {
  config_load "$CONF"
  config_foreach start_instance naive
}

reload_service() {
  stop
  start
}

service_triggers() {
  procd_add_reload_trigger "$CONF"
}
